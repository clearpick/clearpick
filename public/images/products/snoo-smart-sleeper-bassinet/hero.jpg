ental\",\"snoo_being_used\":\"SNOO is being used\",\"snoo_in_transit\":\"SNOO is in transit\",\"snoo_inspected\":\"SNOO received and inspected\",\"shipping_address\":\"Shipping Address\",\"month\":\"Month\",\"billing_info\":\"Billing Information\",\"loading_billing\":\"Loading billing info...\",\"next_payment\":\"Next Payment\",\"payment_date\":\"Payment Date\",\"billing_period\":\"Billing Period\",\"next_billing_date\":\"Next Billing Date\",\"next_billing_amount\":\"Next Billing Amount\",\"tax\":\"Tax\",\"monthly_rate\":\"Monthly Rate\",\"order_canceled\":\"This order has been canceled\",\"rental_canceled_success\":\"Rental canceled successfully\",\"rental_canceled_error\":\"Failed to cancel rental. Please try again.\",\"order_canceled_success\":\"Order canceled successfully\",\"order_canceled_error\":\"Failed to cancel order. Please try again.\",\"shipping_date_updated\":\"Shipping date updated successfully\",\"shipping_date_error\":\"Failed to update shipping date. Please try again.\",\"return_cancelled\":\"This return has been cancelled\",\"return_cancelled_title\":\"Your return has been cancelled\",\"return_initiated_title\":\"Your return has been initiated\",\"return_in_transit_title\":\"Your return is in transit\",\"return_inspected_title\":\"Your return has been inspected\",\"return_items\":\"Return Items\",\"order_id\":\"Order ID\",\"download_shipping_label\":\"Download Shipping Label\",\"shipping_label_error\":\"There was an issue creating the shipping label. Please\",\"contact_customer_care\":\"contact Customer Care\",\"view_return_instructions\":\"View Return Instructions\",\"refund_amount\":\"Refunded Amount\",\"schedule_pickup\":\"Schedule Pickup\",\"schedule_pickup_description\":\"Ready for SNOO pick-up? Just click on the button below to schedule it with UPS.\",\"warranty_expired\":\"The 30-day return window for this order has expired.\"},\"return\":{\"title_select_items\":\"Select Items to Return\",\"title_shipping_details\":\"Shipping Details\",\"title_confirm\":\"Confirm Return\",\"title_success\":\"Return Initiated\",\"select_items_label\":\"Select items you wish to return\",\"no_returnable_items\":\"No returnable items found\",\"reason_label\":\"Return Reason\",\"reason_placeholder\":\"Select a reason\",\"sleep_consultation_message\":\"Before returning, consider scheduling a free sleep consultation with our experts. Many families find solutions that help their baby adjust to SNOO.\",\"schedule_consultation\":\"Schedule Free Consultation\",\"items_to_return\":\"Items to Return\",\"shipping_address\":\"Pickup Address\",\"return_shipping_fee\":\"Return Shipping Fee\",\"shipping_fee_note\":\"This fee plus applicable tax will be charged to your payment method on file.\",\"refund_summary\":\"Refund Summary\",\"refund_subtotal\":\"Items Subtotal\",\"restocking_fee\":\"Restocking Fee\",\"shipping_fee\":\"Shipping Fee\",\"estimated_refund\":\"Estimated Refund\",\"first_name\":\"First Name\",\"last_name\":\"Last Name\",\"address\":\"Address\",\"address2\":\"Address Line 2\",\"city\":\"City\",\"state\":\"State\",\"select_state\":\"Select a state\",\"zip\":\"ZIP Code\",\"phone\":\"Phone\",\"cancel\":\"Cancel\",\"continue\":\"Continue\",\"back\":\"Back\",\"submit_return\":\"Submit Return\",\"confirm_return\":\"Confirm Return\",\"submitting\":\"Submitting...\",\"done\":\"Done\",\"success_message\":\"Your return has been initiated successfully. Please follow the instructions below.\",\"download_label\":\"Download Shipping Label\",\"label_instructions\":\"Print this label and attach it to your package.\",\"schedule_pickup\":\"Schedule Pickup\",\"schedule_pickup_note\":\"You can schedule a free carrier pickup at your address.\",\"view_instructions\":\"View Return Instructions\",\"return_initiated_success\":\"Return initiated successfully\",\"return_initiated_error\":\"Failed to initiate return. Please try again.\",\"select_item_first\":\"Please select an item to see available return reasons\",\"commitment_warning_title\":\"Minimum Rental Commitment\",\"commitment_warning_message\":\"Your Newborn Special Plan has a {months}-month minimum commitment. Returning early may result in additional charges to fulfill the commitment period.\",\"instructions\":{\"title\":\"Return Instructions\",\"step1_title\":\"Clean SNOO\",\"step1_description\":\"Clean excessive dirt, debris, spit up, and other stains from SNOO before returning to avoid deductions from your security deposit refund. Follow the cleaning instructions in this blog and video: https://www.happiestbaby.com/blogs/snoo/how-to-clean-snoo\",\"step2_title\":\"Pack SNOO\",\"step2_description\":\"Carefully pack SNOO in the original packaging and box following this helpful video: https://www.youtube.com/watch?v=mlDR_LSFX0I\u0026feature=youtu.be (do not include the SNOO Sacks, sheet, mattress, and printed materials—they're yours to keep).\",\"step3_title\":\"Download and print label\",\"step3_description\":\"Download and print the shipping label. Make sure to remove the old shipping label before attaching the new shipping label.\",\"step4_title\":\"Ship SNOO\",\"step4_description\":\"Attach the label to the box and schedule a UPS pickup or drop it off at your nearest UPS location. Please note that it takes about an hour after your label is generated to schedule a pickup. (If the return is not postmarked within 10 days of receiving the shipping label, the return will be cancelled, after which a new return must be initiated.)\",\"step5_title\":\"Use provided label\",\"step5_description\":\"You must use the shipping label provided by Happiest Baby. If you do not, the package will be rejected and returned to you at your cost.\",\"download_label\":\"Download Shipping Label\",\"warning\":\"Note: SNOO is heavy and can be damaged if NOT returned in the original box + packaging. If your SNOO is damaged during the return you will be held responsible.\",\"close\":\"Close\"}},\"payment\":{\"page_title\":\"Payment Management\",\"payment_method_title\":\"Pa